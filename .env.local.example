# Supabase — get these from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for embed snippet generation)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Encryption key for storing LLM API keys (run: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-byte-hex-key

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create in Stripe Dashboard > Products
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
